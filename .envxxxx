# The default value is: "runtime"
RUNTIME_DIR = "runtime"

# The default value is: "resource"
RESOURCE_DIR = "resource"

# 放置自定义的各种文件
# The default value is: "custom"
CUSTOM_DIR = "custom"

# 启动Web服务器的端口号
# The default value is: 8080
WEB_SERVER_PORT = 8999

# 是否输出SQL调试信息
# The default value is: false
SHOW_SQL = false

# 数据库类型: mysql,sqlite3,postgres
# The default value is: "postgres"
DB_DRIVER = "postgres"

# 数据库主机地址
# The default value is: "127.0.0.1"
DB_HOST = "127.0.0.1"

# 数据库名
# The default value is: "postgres"
DB_NAME = "postgres"

# 数据库schema
# The default value is: "public"
DB_SCHEMA = "public"

# 数据库端口号:5432(postgres);3306(mysql)
# The default value is: 5432
DB_PORT = 5432

# 数据库用户名
# The default value is: "postgres"
DB_USERNAME = "postgres"

# 数据库密码
# The default value is: "postgres"
DB_PASSWORD = "postgres"

# 数据库节点号
# The default value is: 1
DB_NODE_ID = 1

# 加密倍数
# The default value is: 2
ENCRYPT_MULTIPLE = 2

# 加密增量
# The default value is: 10086
ENCRYPT_ADD = 10086

# 跳转目标的URL前缀。如：https://www.baidu.com
# The default value is: ""
TO_BASE_URL = ""